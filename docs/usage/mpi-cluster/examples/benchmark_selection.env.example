# Shell-sourced example manifest for the generic N-node cluster rerun.
# In the normal benchmark flow this file is generated automatically by:
#   bash ./scripts/run_calibrate_target.sh
# or:
#   bash ./scripts/run_all_experiments.sh
#
# For the generic cluster wrapper you can either:
# 1. copy a previously generated results/benchmark_selection.env into
#    .cache/cluster/benchmark_selection.env
# 2. copy this file into .cache/cluster/benchmark_selection.env and replace
#    every value below with the already-chosen workload settings
#
# Keep this file as plain POSIX-shell NAME=value assignments only. The generic
# cluster bundle copies and sources it directly.

N_SELECTED=10000000
N_SPEEDUP=2000000
P_SELECTED=12
D=384
Q=400
K=10
EPSILON=1e-5

# Use N_ONLY when the chosen selected workload came directly from the initial N
# sweep. Use N_PLUS_Q only when the chosen workload required fallback Q
# escalation after the largest feasible N was still below the target runtime.
CALIBRATION_MODE=N_PLUS_Q

# If you know the largest successful N from the original calibration story, use
# it here. Otherwise keep this equal to N_SELECTED when authoring the manifest
# manually.
N_MAX_FEASIBLE=10000000
