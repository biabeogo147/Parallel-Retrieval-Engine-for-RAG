# Shell-sourced example config for:
#   bash ./scripts/run_cluster_two_node_bundle.sh --config .cache/cluster/two_node_bundle.env
#
# Copy this file into a repo-local untracked path such as:
#   .cache/cluster/two_node_bundle.env
# Then replace the values below with the real hostfile path, worker host, and
# any benchmark overrides you want to use for the current rerun.
#
# Keep this file as plain POSIX-shell variable assignments only. The bundle
# script sources it directly.

CLUSTER_HOSTFILE="$HOME/work/Parallel-Retrieval-Engine-for-RAG/.cache/cluster/hosts.local-plus-199"
CLUSTER_WORKER_HOST="rag-worker1"
CLUSTER_WORKER_REPO_ROOT="$HOME/work/Parallel-Retrieval-Engine-for-RAG"
CLUSTER_SERVER_SLOTS=4
CLUSTER_HEAD_LAN_CIDR="192.168.1.0/24"

# Optional topology-name overrides. Leave the defaults if you already use the
# canonical hostnames from the validated two-node runbook.
CLUSTER_HEAD_MPI_HOST="rag-header"
CLUSTER_WORKER_MPI_HOST="rag-worker1"
CLUSTER_RUN_TAG_PREFIX="two-nodes"

# Optional output overrides. By default the bundle writes to:
#   $HOME/data/pdp_retrieve_engine/results/cluster/<run-tag>/
#   $HOME/data/pdp_retrieve_engine/scratch/cluster_bundle/<run-tag>/
# while keeping lightweight repo-local runtime symlinks under:
#   .cache/cluster_runtime/<run-tag>/
BENCH_BUILD_DIR="$HOME/work/Parallel-Retrieval-Engine-for-RAG/build/release"
BENCH_STORAGE_ROOT="$HOME/data/pdp_retrieve_engine"
CLUSTER_RUNTIME_ROOT="$HOME/work/Parallel-Retrieval-Engine-for-RAG/.cache/cluster_runtime"
CLUSTER_DOCS_OUTPUT="$HOME/work/Parallel-Retrieval-Engine-for-RAG/docs/analysis/latest-cluster-benchmark-review.md"

# Canonical calibration defaults from the maintained benchmark policy.
BENCH_D=384
BENCH_Q=100
BENCH_TOPK=10
BENCH_EPSILON=1e-5
BENCH_N_CANDIDATES="4000000 6000000 8000000 10000000"
BENCH_Q_CANDIDATES="150 200 250 300 400 500 600"
BENCH_SPEEDUP_N_CANDIDATES="2000000 3000000 4000000 5000000"
BENCH_SPEEDUP_BASELINE_LIMIT=600

# Optional manual override. If you leave this unset, the bundle derives a
# default process list from the detected head-node physical cores and the fixed
# worker slot budget.
# BENCH_P_LIST="2 4 8 10 12 14"
