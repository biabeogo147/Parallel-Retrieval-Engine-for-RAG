# Shell-sourced example config for:
#   bash ./scripts/run_cluster_n_node_bundle.sh --config .cache/cluster/n_node_bundle.env
#
# Copy this file into a repo-local untracked path such as:
#   .cache/cluster/n_node_bundle.env
# Then replace the values below with the real hostfile path, selection-manifest
# path, and the already-synchronized dataset paths that exist identically on
# every node.
#
# Keep this file as plain POSIX-shell variable assignments only. The bundle
# script sources it directly.

CLUSTER_HOSTFILE="$HOME/work/Parallel-Retrieval-Engine-for-RAG/.cache/cluster/hosts.cluster"
CLUSTER_SELECTION_ENV="$HOME/work/Parallel-Retrieval-Engine-for-RAG/.cache/cluster/benchmark_selection.env"
CLUSTER_SELECTED_MEMORY_PATH="$HOME/work/Parallel-Retrieval-Engine-for-RAG/data/cluster_selected/memory_vectors.bin"
CLUSTER_SELECTED_QUERY_PATH="$HOME/work/Parallel-Retrieval-Engine-for-RAG/data/cluster_selected/query_vectors.bin"
CLUSTER_SPEEDUP_MEMORY_PATH="$HOME/work/Parallel-Retrieval-Engine-for-RAG/data/cluster_speedup/memory_vectors.bin"
CLUSTER_HEAD_LAN_CIDR="192.168.1.0/24"

# Optional. If omitted, the speedup sweep reuses CLUSTER_SELECTED_QUERY_PATH.
# CLUSTER_SPEEDUP_QUERY_PATH="$HOME/work/Parallel-Retrieval-Engine-for-RAG/data/cluster_speedup/query_vectors.bin"

# Optional output overrides. By default the bundle writes to:
#   $HOME/data/pdp_retrieve_engine/results/cluster/<run-tag>/
#   $HOME/data/pdp_retrieve_engine/scratch/cluster_bundle/<run-tag>/
BENCH_BUILD_DIR="$HOME/work/Parallel-Retrieval-Engine-for-RAG/build/release"
BENCH_STORAGE_ROOT="$HOME/data/pdp_retrieve_engine"
CLUSTER_DOCS_OUTPUT="$HOME/work/Parallel-Retrieval-Engine-for-RAG/docs/analysis/latest-cluster-benchmark-review.md"

# Optional run-tag prefix if you do not pass --run-tag.
CLUSTER_RUN_TAG_PREFIX="n-node"

# Optional. If omitted, the bundle derives a small ascending list from the
# summed hostfile slot budget.
# BENCH_P_LIST="2 4 8 12"
